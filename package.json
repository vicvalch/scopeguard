{
  "name": "pmfreak",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "npm run lint:aoc-boundaries && eslint",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.mjs",
    "lint:aoc-boundaries": "node scripts/lint-aoc-boundaries.mjs",
    "check:aoc-packages": "node scripts/check-aoc-packages.mjs",
    "check:aoc-deps": "node scripts/check-aoc-dependency-direction.mjs",
    "check:aoc-boundaries": "npm run lint:aoc-boundaries && npm run check:aoc-packages && npm run check:aoc-deps",
    "check:no-local-auth-bypass": "node scripts/check-no-local-authority-bypass.mjs",
    "build:aoc:protocol": "npm --prefix src/aoc/protocol run build",
    "build:aoc:enterprise": "npm --prefix src/aoc/enterprise run build",
    "build:aoc": "npm run build:aoc:protocol && npm run build:aoc:enterprise",
    "check:runtime-contract-drift": "node scripts/check-runtime-contract-drift.mjs",
    "check:package-exports": "node scripts/check-package-exports.mjs",
    "check:publish-ready": "node scripts/validate-publish-ready.mjs",
    "check:compatibility": "node scripts/check-compatibility-governance.mjs",
    "check:lifecycle": "node scripts/check-lifecycle-integrity.mjs",
    "check:release-readiness": "node scripts/check-release-readiness.mjs",
    "publish:dry-run": "node scripts/publish-dry-run.mjs",
    "check:governance": "npm run check:aoc-boundaries && npm run check:no-local-auth-bypass && npm run check:runtime-contract-drift && npm run check:package-exports && npm run check:compatibility && npm run check:lifecycle && npm run check:release-readiness && npm run check:package-purity",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "check:forbidden-imports": "node scripts/check-forbidden-imports.mjs",
    "check:tarball-purity": "node scripts/check-tarball-purity.mjs",
    "check:build-reproducibility": "node scripts/check-build-reproducibility.mjs",
    "check:package-purity": "npm run check:forbidden-imports && npm run check:package-exports && npm run check:typescript-package-isolation && npm run check:tarball-purity",
    "check:publish-integrity": "npm run build:aoc && npm run check:package-purity && npm run check:build-reproducibility",
    "check:typescript-package-isolation": "node scripts/check-typescript-package-isolation.mjs",
    "test:launch-smoke": "node scripts/run-launch-smoke-tests.mjs",
    "diag:runtime": "node scripts/runtime-diagnostics-report.mjs",
    "check:launch-readiness": "node scripts/check-launch-readiness.mjs",
    "smoke-test:vault": "node scripts/smoke-test-vault-digestion.mjs",
    "check:operational-memory": "node scripts/check-operational-memory-runtime.mjs",
    "check:nutrient-bridge": "node scripts/check-nutrient-operational-bridge.mjs",
    "check:runtime-contracts": "node scripts/check-runtime-contracts.mjs",
    "check:governance-typing": "node scripts/check-governance-typing.mjs",
    "check:sdk-boundaries": "node scripts/check-sdk-boundaries.mjs",
    "check:runtime-normalization": "node scripts/check-runtime-normalization.mjs",
    "check:trust-contracts": "node scripts/check-trust-contracts.mjs",
    "check:continuity-retrieval": "node scripts/check-operational-continuity-retrieval.mjs"
  },
  "dependencies": {
    "@aoc-enterprise/runtime": "file:src/aoc/enterprise",
    "@aoc/protocol": "file:src/aoc/protocol",
    "@supabase/auth-helpers-nextjs": "^0.15.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.104.1",
    "framer-motion": "^12.38.0",
    "jspdf": "^4.2.1",
    "mammoth": "^1.12.0",
    "next": "16.2.4",
    "pdf-parse": "^2.4.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "^18.5.0",
    "swr": "^2.4.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "@changesets/cli": "^2.29.6"
  }
}
