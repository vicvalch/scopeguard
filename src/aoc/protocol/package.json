{
  "name": "@aoc/protocol",
  "version": "0.1.0",
  "description": "AOC protocol contracts \u2014 capability claim types, issuance, and cryptographic verification",
  "license": "UNLICENSED",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./contracts": {
      "types": "./dist/contracts/index.d.ts",
      "import": "./dist/contracts/index.js"
    },
    "./contracts/*": {
      "types": "./dist/contracts/*.d.ts",
      "import": "./dist/contracts/*.js"
    },
    "./actor-model": {
      "types": "./dist/actor-model.d.ts",
      "import": "./dist/actor-model.js"
    },
    "./ports": {
      "types": "./dist/ports/index.d.ts",
      "import": "./dist/ports/index.js"
    },
    "./ports/*": {
      "types": "./dist/ports/*.d.ts",
      "import": "./dist/ports/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Architects-of-Change-Protocol/pmfreak.git",
    "directory": "src/aoc/protocol"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "peerDependencies": {},
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc -p tsconfig.build.json"
  }
}
